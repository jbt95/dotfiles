{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "default_agent": "plan",
  "provider": {
    "fireworks-ai": {
      "options": {
        "apiKey": "YOUR_FIREWORKS_API_KEY_HERE"
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "docs/**/*.md"
  ],
  "plugin": [
    "@plannotator/opencode@latest"
  ],
  "permission": {
    "external_directory": {
      "*": "allow",
      "**/.ssh/**": "deny",
      "**/.aws/**": "deny",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    },
    "edit": "allow",
    "bash": {
      "*": "allow",
      "printenv *": "deny",
      "env": "deny",
      "env *": "deny",
      "export *": "deny",
      "gh auth *": "deny",
      "cat *.env": "deny",
      "cat *.env.*": "deny",
      "cat **/.env": "deny",
      "cat **/.env.*": "deny",
      "cat *.envrc": "deny",
      "cat **/.envrc": "deny",
      "cat .dev.vars": "deny",
      "cat **/.dev.vars": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "cat **/.aws/**": "deny",
      "cat **/.ssh/**": "deny"
    },
    "webfetch": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.envrc": "deny",
      ".dev.vars": "deny",
      "**/.dev.vars": "deny",
      "secrets/*": "deny",
      "**/secrets/**": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "tools": {
    "todowrite": true,
    "todoread": true
  },
  "mcp": {
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_CONTEXT7_API_KEY_HERE"
      },
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "opensrc": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "opensrc-mcp"
      ],
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "target/**",
      "coverage/**",
      ".next/**",
      ".turbo/**",
      "*.log"
    ]
  }
}
